# ==========================================
# 1. Настройки AI-моделей (GigaChat / OpenAI)
# ==========================================
# Авторизационные данные GigaChat (Base64 токен, полученный в Studio Sber)
GIGACHAT_CREDENTIALS="твой_длинный_токен_base64_здесь"

# Альтернатива: если решишь использовать классический стек OpenAI (опционально)
# OPENAI_API_KEY="sk-..."

# ==========================================
# 2. Настройки LangSmith (Трассировка и дебаг AI-агента)
# ==========================================
# Включение мониторинга (true/false)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
# Ключ от аккаунта LangSmith (начинается на lsv2_...)
LANGCHAIN_API_KEY="твой_ключ_langsmith_здесь"
# Название проекта в дашборде LangSmith
LANGCHAIN_PROJECT="fleet-ai-project"

# ==========================================
# 3. Настройки Базы Данных (PostgreSQL / SQLite)
# ==========================================
# Для локального запуска (без Docker) используем SQLite:
# DATABASE_URL="sqlite:///./fleet.db"
# Для запуска через docker-compose (PostgreSQL):
DATABASE_URL="postgresql://user:password@db:5432/fleet_db"

# ==========================================
# 4. Настройки Celery и Redis (Фоновые задачи)
# ==========================================
# URL брокера сообщений. При запуске через docker-compose хост называется 'redis'
CELERY_BROKER_URL="redis://redis:6379/0"
CELERY_RESULT_BACKEND="redis://redis:6379/0"

# ==========================================
# 5. Настройки FastAPI
# ==========================================
# Порт и хост для запуска uvicorn (если запускаешь локально без Docker)
HOST="0.0.0.0"
PORT=8000
